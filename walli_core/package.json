    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "tailwindcss": "^4.3.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10",
    "wrangler": "4.111.0"
  },
  "private": true,
  "scripts": {
    "build": "tsc -b && vite build",
    "cf-typegen": "wrangler types",
    "check": "tsc && vite build && wrangler deploy --dry-run",
    "deploy": "pnpm migrations:generate && pnpm db:migrate:remote && vite build && wrangler deploy",
    "deploy:dist": "wrangler deploy",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "pnpm build && vite preview",
    "secrets": "node scripts/put-secrets.mjs",
    "migrations:generate": "drizzle-kit generate && drizzle-kit generate --config drizzle.user-do.config.ts",
    "migrations:check": "drizzle-kit check && drizzle-kit check --config drizzle.user-do.config.ts",
    "db:migrate:local": "wrangler d1 migrations apply walli_core --local",
    "db:migrate:remote": "wrangler d1 migrations apply walli_core --remote",
    "db:migrations:list:local": "wrangler d1 migrations list walli_core --local",
    "db:migrations:list:remote": "wrangler d1 migrations list walli_core --remote",
    "test": "vitest run"
  },
  "type": "module"
}
